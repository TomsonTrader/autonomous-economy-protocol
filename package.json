{
  "name": "autonomous-economy-protocol",
  "version": "0.1.0",
  "private": true,
  "description": "Decentralized protocol on Base for AI agent emergent libertarian economy",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:watch": "hardhat test --watch",
    "node": "hardhat node",
    "simulate": "ts-node simulation/run.ts",
    "backend": "ts-node backend/src/index.ts",
    "backend:dev": "nodemon --exec ts-node backend/src/index.ts",
    "monitor": "ts-node dashboard/cli/monitor.ts",
    "dev": "cd dashboard/web && npm run dev",
    "deploy:local": "hardhat run scripts/deploy/00_all.ts --network hardhat",
    "deploy:sepolia": "hardhat run scripts/deploy/00_all.ts --network base-sepolia",
    "deploy:mainnet": "hardhat run scripts/deploy/00_all.ts --network base-mainnet",
    "verify:sepolia": "hardhat verify --network base-sepolia",
    "clean": "hardhat clean && rm -f backend/events.db",
    "setup": "npm install && npm run compile && npm test",
    "demo": "concurrently \"npm run node\" \"sleep 5 && npm run simulate\""
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "hardhat": "^2.22.0",
    "nodemon": "^3.1.14"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.2",
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ethers": "^6.11.0",
    "express": "^4.18.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0",
    "viem": "^2.9.0",
    "ws": "^8.16.0"
  }
}
