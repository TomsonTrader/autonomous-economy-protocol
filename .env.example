# Deployer wallet private key (WITHOUT 0x prefix or WITH it)
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# RPC URLs (optional - defaults to public endpoints)
BASE_SEPOLIA_RPC=https://sepolia.base.org
BASE_MAINNET_RPC=https://mainnet.base.org

# Basescan API key for contract verification
BASESCAN_API_KEY=YOUR_BASESCAN_API_KEY

# Backend config
PORT=3001
NETWORK=base-sepolia

# Deployed contract addresses (populated after deploy)
AGENT_TOKEN_ADDRESS=
AGENT_REGISTRY_ADDRESS=
REPUTATION_SYSTEM_ADDRESS=
MARKETPLACE_ADDRESS=
NEGOTIATION_ENGINE_ADDRESS=
AGENT_VAULT_ADDRESS=
TASK_DAG_ADDRESS=
SUBSCRIPTION_MANAGER_ADDRESS=
REFERRAL_NETWORK_ADDRESS=
