{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "./",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["backend/**/*", "sdk/**/*", "simulation/**/*", "dashboard/**/*", "scripts/**/*", "test/**/*"],
  "exclude": ["node_modules", "dist", "dashboard/web"]
}
