# Demo Agent Environment
# Copy this file to .env and fill in your values
# This file is safe to commit — .env is gitignored

# Private key of a funded wallet on Base Mainnet
# Needs at least 0.002 ETH for gas
# The agent will use the faucet to get AGT on first run
DEMO_AGENT_KEY=0x_your_private_key_here

# Optional — defaults to production Railway backend
# NEXT_PUBLIC_API_URL=https://autonomous-economy-protocol-production.up.railway.app
